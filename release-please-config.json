{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "simple",
  "bump-minor-pre-major": true,
  "bump-patch-for-minor-pre-major": false,
  "include-component-in-tag": false,
  "changelog-sections": [
    { "type": "feat", "section": "Features" },
    { "type": "fix", "section": "Bug Fixes" },
    { "type": "perf", "section": "Performance" },
    { "type": "refactor", "section": "Code Refactoring", "hidden": true },
    { "type": "docs", "section": "Documentation", "hidden": true },
    { "type": "chore", "section": "Miscellaneous", "hidden": true },
    { "type": "test", "section": "Tests", "hidden": true },
    { "type": "ci", "section": "CI", "hidden": true }
  ],
  "packages": {
    ".": {
      "extra-files": [
        {
          "type": "toml",
          "path": "Cargo.toml",
          "jsonpath": "$.workspace.package.version"
        },
        {
          "type": "toml",
          "path": "crates/crw-core/Cargo.toml",
          "jsonpath": "$.dependencies.crw-core.version"
        },
        {
          "type": "toml",
          "path": "crates/crw-renderer/Cargo.toml",
          "jsonpath": "$.dependencies.crw-core.version"
        },
        {
          "type": "toml",
          "path": "crates/crw-extract/Cargo.toml",
          "jsonpath": "$.dependencies.crw-core.version"
        },
        {
          "type": "toml",
          "path": "crates/crw-crawl/Cargo.toml",
          "jsonpath": "$.dependencies.crw-core.version"
        },
        {
          "type": "toml",
          "path": "crates/crw-crawl/Cargo.toml",
          "jsonpath": "$.dependencies.crw-renderer.version"
        },
        {
          "type": "toml",
          "path": "crates/crw-crawl/Cargo.toml",
          "jsonpath": "$.dependencies.crw-extract.version"
        },
        {
          "type": "toml",
          "path": "crates/crw-server/Cargo.toml",
          "jsonpath": "$.dependencies.crw-core.version"
        },
        {
          "type": "toml",
          "path": "crates/crw-server/Cargo.toml",
          "jsonpath": "$.dependencies.crw-renderer.version"
        },
        {
          "type": "toml",
          "path": "crates/crw-server/Cargo.toml",
          "jsonpath": "$.dependencies.crw-extract.version"
        },
        {
          "type": "toml",
          "path": "crates/crw-server/Cargo.toml",
          "jsonpath": "$.dependencies.crw-crawl.version"
        },
        {
          "type": "toml",
          "path": "crates/crw-cli/Cargo.toml",
          "jsonpath": "$.dependencies.crw-core.version"
        },
        {
          "type": "toml",
          "path": "crates/crw-cli/Cargo.toml",
          "jsonpath": "$.dependencies.crw-renderer.version"
        },
        {
          "type": "toml",
          "path": "crates/crw-cli/Cargo.toml",
          "jsonpath": "$.dependencies.crw-extract.version"
        },
        {
          "type": "toml",
          "path": "crates/crw-cli/Cargo.toml",
          "jsonpath": "$.dependencies.crw-crawl.version"
        },
        {
          "type": "toml",
          "path": "crates/crw-mcp/Cargo.toml",
          "jsonpath": "$.dependencies.crw-core.version"
        },
        {
          "type": "toml",
          "path": "crates/crw-mcp/Cargo.toml",
          "jsonpath": "$.dependencies.crw-server.version"
        },
        {
          "type": "toml",
          "path": "Cargo.toml",
          "jsonpath": "$.workspace.dependencies.crw-pdf.version"
        },
        {
          "type": "json",
          "path": "server.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "npm/crw-mcp/package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "npm/crw-mcp-darwin-x64/package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "npm/crw-mcp-darwin-arm64/package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "npm/crw-mcp-linux-x64/package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "npm/crw-mcp-linux-arm64/package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "npm/crw-mcp-win32-x64/package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "npm/crw-mcp-win32-arm64/package.json",
          "jsonpath": "$.version"
        }
      ]
    }
  }
}
